<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive{% if include.limit and page.announcements.scrollable %} news-scroll-fit{% endif %}"
      {% if include.limit and page.announcements.scrollable %}
        style="overflow-y: auto;"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 12%; font-weight: normal;">{{ item.date | date: '%b %d %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>

{% if include.limit and page.announcements.scrollable %}
  <style>
    @media (max-width: 768px) {
      .news-scroll-fit {
        overflow-y: visible !important;
        max-height: none !important;
      }
    }
  </style>
  <script>
    (function () {
      var MOBILE_MAX_WIDTH = 768;
      function isMobile() {
        return window.innerWidth <= MOBILE_MAX_WIDTH;
      }
      function adjustNewsHeight() {
        var el = document.querySelector('.news-scroll-fit');
        if (!el) return;
        if (isMobile()) {
          el.style.maxHeight = '';
          return;
        }
        var rect = el.getBoundingClientRect();
        var topInDoc = rect.top + window.scrollY;
        var docHeight = document.documentElement.scrollHeight;
        var belowInDoc = docHeight - (topInDoc + rect.height);
        var available = window.innerHeight - topInDoc - belowInDoc;
        el.style.maxHeight = Math.max(180, available) + 'px';
      }
      var raf;
      function schedule() {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(adjustNewsHeight);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', schedule);
      } else {
        schedule();
      }
      window.addEventListener('load', schedule);
      window.addEventListener('resize', schedule);
    })();
  </script>
{% endif %}
